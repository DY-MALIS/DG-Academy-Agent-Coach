rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.role in ['student', 'admin'] &&
             data.createdAt is timestamp &&
             (data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt'])) &&
             data.keys().size() == 6;
    }

    function isValidProfile(data) {
      return (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 500));
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category in ["AI Skill Learning", "Digital Skill", "Business Skill", "Career Skill", "Automation Skill"] &&
             data.isPublished is bool &&
             data.createdAt is timestamp;
    }

    function isValidLesson(data) {
      return data.courseId is string && isValidId(data.courseId) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.order is int &&
             data.type in ["text", "video"];
    }

    function isValidPrompt(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.category is string &&
             data.createdAt is timestamp;
    }

    // --- Collection Matches ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (incoming().role == 'student' || (incoming().role == 'admin' && incoming().email == 'tsokunthea5@gmail.com'));
      allow update: if (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'role'])) || isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidProfile(incoming());
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidCourse(incoming()));
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidLesson(incoming()));
    }

    match /roadmaps/{roadmapId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roadmap_steps/{stepId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /prompts/{promptId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidPrompt(incoming()));
    }

    match /user_progress/{progressId} {
      allow read: if isOwner(existing().userId);
      allow write: if isOwner(incoming().userId) && isValidId(incoming().lessonId);
    }

    match /problem_reports/{reportId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(incoming().userId);
      allow delete: if isOwner(existing().userId);
    }

    match /chat_history/{userId} {
      allow get: if isOwner(userId);
      allow write: if isOwner(userId) && incoming().messages is list && incoming().messages.size() <= 100;
    }
  }
}
